{
  "name": "sdk-node-examples",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint examples/",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@gatectr/sdk": "^0.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "examples/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
