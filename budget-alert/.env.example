# Required — your GateCtr API key. Get it at https://app.gatectr.com/api-keys
GATECTR_API_KEY=gtr_your_api_key_here

# Required — your Slack incoming webhook URL
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Port for the webhook receiver (default: 3002)
PORT=3002
